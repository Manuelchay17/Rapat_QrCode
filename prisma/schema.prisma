generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Event {
  id           String    @id @default(cuid())
  title        String
  dateRaw      String
  time         String
  endTime      String?   // Tambahkan ini untuk menyimpan jam selesai
  location     String
  description  String?
  participants Int       @default(0)
  status       String    @default("active")
  createdAt    DateTime  @default(now())
  rapat_type   String    @default("with_reg")
  absensi      Absensi[]
}

model Absensi {
  id                 Int      @id @default(autoincrement())
  rapat_id           String
  participant_name   String   // Sekarang hanya string biasa, tidak terkunci ke tabel lain
  check_in_time      String?
  status             String   @default("registered")
  division           String?
  signature_at_event String?  @db.Text // Gunakan @db.Text jika string tanda tangan sangat panjang

  // Relasi hanya ke Event
  event              Event    @relation(fields: [rapat_id], references: [id])

  @@map("absensi")
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique // Gunakan email sebagai ID unik
  password  String   
  createdAt DateTime @default(now())

  @@map("admins")
}